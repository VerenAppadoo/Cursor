# app.component.html — ALWAYS START WITH THIS EXACT STRUCTURE

<soho-icons-new></soho-icons-new>
<soho-icons-empty-new></soho-icons-empty-new>

<section class="masthead">
  <div class="flex-toolbar" data-options="{maxVisibleButtons: 6}">
    <div class="toolbar-section">
      <button type="button" class="masthead-icon">
        <svg class="icon icon-logo" focusable="false" aria-hidden="true" role="presentation">
          <use href="#icon-logo"></use>
        </svg>
        <span class="audible">Go To Home</span>
      </button>
    </div>
    <div class="toolbar-section title">
      <h1 class="masthead-appname">{{appTitle}}</h1>
    </div>
    <div class="toolbar-section buttonset">
      <button type="button" class="btn" id="versionbtn"
        (click)="headerPanelVersion()">{{appVersion.version}}</button>
    </div>
  </div>
</section>

