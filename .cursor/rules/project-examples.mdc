## Key Patterns — Always Follow These

### 1. Standalone Components (preferred, used in Quick-Price-Quote)

Reference: `Quick-Price-Quote/src/app/features/home/components/search/search/search.component.ts`

```typescript
import { Component, OnInit, ViewChild, ViewContainerRef } from '@angular/core';
import { NgFor, NgIf } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { TranslocoDirective } from '@jsverse/transloco';
import { MIService } from '@infor-up/m3-odin-angular';
import { IMIRequest, MIRecord } from '@infor-up/m3-odin';
import {
  SohoButtonModule,
  SohoDropDownModule,
  SohoBusyIndicatorModule,
  // ... import ONLY the individual Soho modules the component uses
} from 'ids-enterprise-ng';

@Component({
  selector: 'app-my-component',
  templateUrl: './my-component.component.html',
  styleUrl: './my-component.component.css',
  standalone: true,
  imports: [
    TranslocoDirective,
    NgFor, NgIf,
    FormsModule,
    SohoButtonModule,
    SohoDropDownModule,
    SohoBusyIndicatorModule,
    // other standalone child components
  ],
})
export class MyComponent implements OnInit {
  constructor(private readonly miService: MIService) {}
  ngOnInit(): void {}
}
```

**Rules for standalone components:**
- Import IDS modules **individually** (e.g. `SohoButtonModule`, `SohoDropDownModule`) — NOT `SohoComponentsModule` as a whole.
- Add `TranslocoDirective` to imports when using translations.
- Keep `standalone: true` on all new components.

