### 4. Store Pattern (State Management)

Reference: `Quick-Price-Quote/src/app/core/models/store.ts` and `global.store.ts`

**Base store class** (already exists in projects — reference, do not re-create):
```typescript
import { Observable, BehaviorSubject } from 'rxjs';
import { environment } from '@environments/environment';

export class Store<T> {
  state$: Observable<T>;
  private _state$: BehaviorSubject<T>;

  protected constructor(initialState: T, storeName: string) {
    this._state$ = new BehaviorSubject(initialState);
    this.state$ = this._state$.asObservable();
  }

  get state(): T { return this._state$.getValue(); }

  setState(nextState: T): void {
    this._state$.next(nextState);
  }
}
```

**Creating a feature store:**
```typescript
import { Injectable } from '@angular/core';
import { Store } from '@core/models';

interface IMyFeatureStore {
  items: MyItem[];
  selectedItem: MyItem | null;
  isLoading: boolean;
}

@Injectable({ providedIn: 'root' })
export class MyFeatureStore extends Store<IMyFeatureStore> {
  constructor() {
    super({ items: [], selectedItem: null, isLoading: false }, 'MyFeatureStore');
  }

  update(data: Partial<IMyFeatureStore>): void {
    this.setState({ ...this.state, ...data });
  }
}
```

